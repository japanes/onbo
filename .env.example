# Copy to .env and uncomment ONE llm block. Everything else has a working
# default in config/settings.yaml, so .env can stay this short.
#
#   cp .env.example .env && docker compose up -d

# =============================================================================
# LLM (used by the classifier and the welcome digest)
# LLM_MODEL is a LiteLLM model string. Set LLM_API_BASE only for self-hosted
# servers — for hosted vendors it MUST stay unset, or requests go to the wrong
# host. Without a reachable model onbo still answers, but on a keyword-matching
# fallback: no free-form understanding.
# =============================================================================

# --- Ollama on the host, open weights on your GPU (default model) ------------
# Install: https://ollama.com  ->  ollama pull llama3.2:3b
# The container reaches the host only if Ollama listens on all interfaces:
#   systemctl edit ollama   ->   [Service] Environment="OLLAMA_HOST=0.0.0.0"
# LLM_MODEL=ollama_chat/llama3.2:3b
# LLM_API_BASE=http://host.docker.internal:11434

# --- Ollama inside Docker (nothing to install; CPU-only, so slower) ----------
#   docker compose --profile ollama up -d
#   docker compose exec ollama ollama pull llama3.2:3b
# LLM_MODEL=ollama_chat/llama3.2:3b
# LLM_API_BASE=http://ollama:11434

# --- Any other OpenAI-compatible server: vLLM, LM Studio, llama.cpp, a proxy --
# LLM_MODEL=openai/Qwen/Qwen2.5-7B-Instruct
# LLM_API_BASE=http://host.docker.internal:8000/v1
# LLM_API_KEY=not-needed

# --- OpenAI ------------------------------------------------------------------
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- Anthropic ---------------------------------------------------------------
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_API_KEY=sk-ant-...

# --- Google Gemini -----------------------------------------------------------
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=AIza...

# =============================================================================
# Embeddings (open-source, always local via fastembed — no API key, no vendor)
# Changing the model changes the vector size: run `onbo kb reindex` afterwards.
# =============================================================================
# EMBED_MODEL=intfloat/multilingual-e5-large                        # 1024d, default
# EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2   # 384d, light
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2                # 384d, English only

# =============================================================================
# Speech-to-text (faster-whisper, local). In Docker it always runs on CPU, so
# keep the model small; on a host GPU run STT_DEVICE=cuda STT_COMPUTE=float16.
# =============================================================================
# STT_ENABLED=true
# STT_MODEL=base           # base | small | medium | large-v3

# =============================================================================
# Your product: the backend that profile actions call over HTTP.
# Empty PRODUCT_API_BASE = dry run (validate and report, no real request).
# In Docker it defaults to the bundled demo backend.
# =============================================================================
# PRODUCT_NAME=Acme CRM
# PRODUCT_DESCRIPTION=CRM for the sales team
# PRODUCT_API_BASE=https://api.acme.example.com
# PRODUCT_API_KEY=
# PRODUCT_AUTH_HEADER=Authorization
# PRODUCT_AUTH_SCHEME=Bearer

# =============================================================================
# Feature switches (each removes a web mount and/or a routing path)
# =============================================================================
# FEATURE_CHAT=true            # /chat, /voice, /confirm
# FEATURE_ADMIN=true           # /admin KB panel — no auth yet, do not expose publicly
# FEATURE_MEDIA=true           # /media walkthrough videos
# FEATURE_LLM_MANIFEST=true    # /llm.json for external agents
# FEATURE_WELCOME=true         # proactive first-contact digest
# FEATURE_ACTIONS=true         # classifier may run profile actions
# FEATURE_RAG=true             # classifier may answer from the knowledge base

# =============================================================================
# Channels
# =============================================================================
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# WEB_PORT=18000

# =============================================================================
# Infrastructure — set inside docker compose; these defaults are for a HOST run
# (host ports are shifted +10000 to avoid clashing with a local install).
# =============================================================================
# QDRANT_URL=http://localhost:16333
# POSTGRES_DSN=postgresql+psycopg://onbo:onbo@localhost:15432/onbo
# REDIS_URL=redis://localhost:16379/0
# MEDIA_BASE_URL=            # absolute host for /media links in Telegram
