# Copy to .env and fill in the OpenAI key — that is all the default setup needs
# (chat model gpt-5.6-terra + embeddings text-embedding-3-large). Everything
# else here is an alternative: uncomment ONE llm block to switch vendors.
#
#   cp .env.example .env && docker compose up -d
#
# The copy does NOT start as it is: replace the sk-... below with a real key
# first. Left as it is, onbo refuses to start and says so.

OPENAI_API_KEY=sk-...        # <-- REPLACE. LiteLLM reads it for both blocks below

# =============================================================================
# LLM (used by the classifier and RAG answers)
# LLM_MODEL is a LiteLLM model string. Set LLM_API_BASE only for self-hosted
# servers — for hosted vendors it MUST stay unset, or requests go to the wrong
# host. Without a reachable model onbo still answers, but on a keyword-matching
# fallback: no free-form understanding.
# =============================================================================

# --- OpenAI (the default) ----------------------------------------------------
# Nothing to uncomment: OPENAI_API_KEY above is enough, the model is already
# gpt-5.6-terra. This line only pins it explicitly or names another OpenAI model.
# LLM_MODEL=gpt-5.6-terra

# --- Request knobs (all optional; empty = not sent to the provider) ----------
# Flagship reasoning models accept only the default temperature and reject any
# explicit value ("Unsupported value: 'temperature' does not support 0"), so
# these stay EMPTY by default. Set them only for a model that accepts them.
# LLM_TEMPERATURE=0.2
# LLM_TOP_P=1
# LLM_MAX_TOKENS=2000
# Reasoning budget on models that reason: none | minimal | low | medium | high.
# Default is none — classification is a short task, not a thinking one.
# LLM_REASONING_EFFORT=none
# Let LiteLLM strip params the chosen model doesn't support instead of erroring.
# LLM_DROP_UNSUPPORTED=true

# --- Ollama on the host, open weights on your GPU ----------------------------
# Install: https://ollama.com  ->  ollama pull llama3.2:3b
# The container reaches the host only if Ollama listens on all interfaces:
#   systemctl edit ollama   ->   [Service] Environment="OLLAMA_HOST=0.0.0.0"
# LLM_MODEL=ollama_chat/llama3.2:3b
# LLM_API_BASE=http://host.docker.internal:11434

# --- Ollama inside Docker (nothing to install; CPU-only, so slower) ----------
#   docker compose --profile ollama up -d
#   docker compose exec ollama ollama pull llama3.2:3b
# LLM_MODEL=ollama_chat/llama3.2:3b
# LLM_API_BASE=http://ollama:11434

# --- Any other OpenAI-compatible server: vLLM, LM Studio, llama.cpp, a proxy --
# LLM_MODEL=openai/Qwen/Qwen2.5-7B-Instruct
# LLM_API_BASE=http://host.docker.internal:8000/v1
# LLM_API_KEY=not-needed

# --- Anthropic ---------------------------------------------------------------
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_API_KEY=sk-ant-...

# --- Google Gemini -----------------------------------------------------------
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=AIza...

# =============================================================================
# Embeddings — knowledge-base search. Default: OpenAI text-embedding-3-large,
# covered by OPENAI_API_KEY above. Switch to a local model if the knowledge base
# must not leave the machine (see the open-source block below).
# ANY change here changes the vector size: run `onbo kb reindex` afterwards.
# EMBED_PROVIDER=auto guesses local vs hosted from the model string; force it
# with local | api if you point EMBED_API_BASE at your own OpenAI-style server.
# =============================================================================

# --- OpenAI (the default) ----------------------------------------------------
# Nothing to uncomment: OPENAI_API_KEY above is enough, the model is already
# text-embedding-3-large. These lines only pin it or pick the cheaper one.
# EMBED_MODEL=text-embedding-3-large     # 3072d, the default
# EMBED_MODEL=text-embedding-3-small     # 1536d, cheaper
# EMBED_API_KEY=sk-...                   # only if it differs from OPENAI_API_KEY

# --- Open-source, on this machine (no key, nothing leaves the host) ----------
# EMBED_MODEL=intfloat/multilingual-e5-large                        # 1024d, best quality
# EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2   # 384d, light
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2                # 384d, English only

# --- Google Gemini -----------------------------------------------------------
# EMBED_MODEL=gemini/gemini-embedding-001
# EMBED_API_KEY=AIza...

# --- Anthropic: no embedding model of its own, Voyage AI is what it recommends
# EMBED_MODEL=voyage/voyage-3-large      # or voyage/voyage-3.5-lite
# EMBED_API_KEY=pa-...

# --- Anything else LiteLLM speaks (Cohere, Mistral, Bedrock, Azure, a proxy) --
# EMBED_MODEL=cohere/embed-multilingual-v3.0
# EMBED_API_KEY=...
# EMBED_PROVIDER=api                     # needed only when the name looks local
# EMBED_API_BASE=http://host.docker.internal:8000/v1   # self-hosted server only

# =============================================================================
# Speech-to-text (faster-whisper, local). In Docker it always runs on CPU, so
# keep the model small; on a host GPU run STT_DEVICE=cuda STT_COMPUTE=float16.
# =============================================================================
# STT_ENABLED=true
# STT_MODEL=base           # base | small | medium | large-v3

# =============================================================================
# Your product: the backend that profile actions call over HTTP.
# Empty PRODUCT_API_BASE = dry run (validate and report, no real request).
# In Docker it defaults to the bundled demo backend.
# =============================================================================
# PRODUCT_NAME=Acme CRM
# PRODUCT_DESCRIPTION=CRM for the sales team
# PRODUCT_API_BASE=https://api.acme.example.com
# PRODUCT_API_KEY=          # one shared service key; a per-user key in the
#                           # signed token (claim product_token) wins over it
# PRODUCT_AUTH_HEADER=Authorization
# PRODUCT_AUTH_SCHEME=Bearer
# PRODUCT_VERIFY_TLS=true   # false ONLY for a self-signed https://localhost

# =============================================================================
# Who is asking — identity of the person on the other end.
# Default: the caller sends user_id and onbo looks the person up in its users
# table. Good when your own backend is the caller.
# For the chat widget embedded in your site, set ONBO_JWT_SECRET: your backend
# signs a short-lived JWT (sub / department / roles) and onbo trusts it, so no
# copy of your user directory has to live here. Same secret on both sides.
#   ONBO_CORS_ORIGINS is needed only when the browser calls onbo directly.
# =============================================================================
# ONBO_JWT_SECRET=                       # long random string; empty = token auth off
# ONBO_JWT_LEEWAY=30                     # seconds of clock skew tolerated on exp
# ONBO_ALLOW_USER_ID=false               # production: signed token only
# ONBO_CORS_ORIGINS=https://app.example.com

# =============================================================================
# Feature switches (each removes a web mount and/or a routing path)
# =============================================================================
# FEATURE_CHAT=true            # /chat, /voice, /confirm
# FEATURE_ADMIN=true           # /admin KB panel — no auth yet, do not expose publicly
# FEATURE_MEDIA=true           # /media walkthrough videos
# FEATURE_LLM_MANIFEST=true    # /llm.json for external agents
# FEATURE_WELCOME=true         # proactive first-contact greeting
# WELCOME_SMOOTH=false         # let the LLM reword the 3-line greeting (off = instant)
# FEATURE_ACTIONS=true         # classifier may run profile actions
# FEATURE_RAG=true             # classifier may answer from the knowledge base
# ACTIONS_SHORTLIST_SIZE=12    # commands searched out of actions.yaml per message
# ACTIONS_AUTOINDEX=true       # re-embed the catalogue on start when it changed

# =============================================================================
# Channels
# =============================================================================
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# WEB_PORT=18000

# =============================================================================
# Infrastructure — set inside docker compose; these defaults are for a HOST run
# (host ports are shifted +10000 to avoid clashing with a local install).
# =============================================================================
# QDRANT_URL=http://localhost:16333
# POSTGRES_DSN=postgresql+psycopg://onbo:onbo@localhost:15432/onbo
# REDIS_URL=redis://localhost:16379/0
# MEDIA_BASE_URL=            # absolute host for /media links in Telegram
