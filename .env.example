# Copy to .env and fill in what you need. Every value has a sensible default in
# config/settings.yaml, so for a local run .env is OPTIONAL.

# --- LLM (classifier) ---------------------------------------------------------
# Default is a LOCAL model on your GPU via Ollama (ollama pull llama3.2:3b).
# To use a cloud vendor instead, set these two:
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
# Or point at a different local endpoint:
# LLM_MODEL=ollama_chat/qwen2.5:7b
# LLM_API_BASE=http://localhost:11434

# --- Speech-to-text (local GPU) -----------------------------------------------
# STT_MODEL=large-v3     # base | small | medium | large-v3
# STT_DEVICE=cuda        # cuda = local GPU; falls back to cpu if CUDA libs missing
# STT_COMPUTE=float16

# --- Channels -----------------------------------------------------------------
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=

# --- Services (defaults already point at the docker compose stack) ------------
# Host ports are shifted +10000 to avoid clashing with anything already running.
# QDRANT_URL=http://localhost:16333
# POSTGRES_DSN=postgresql+psycopg://onbo:onbo@localhost:15432/onbo
# REDIS_URL=redis://localhost:16379/0
# WEB_PORT=18000
